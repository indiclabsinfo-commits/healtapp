# ─── BACKEND (Railway env vars) ───────────────────────────────────────────────

# Supabase → Project Settings → Database → Connection string (URI mode)
# Change [YOUR-PASSWORD] to your Supabase DB password
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Generate random strings: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="generate-a-strong-random-string"
JWT_REFRESH_SECRET="generate-another-strong-random-string"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

PORT=3001
NODE_ENV="production"

# Your Railway backend URL (set after Railway deploys)
CORS_ORIGIN="https://mindcare.vercel.app"

# Email (optional for demo — use Gmail App Password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"

UPLOAD_DIR="./uploads"

# ─── FRONTEND (Vercel env vars) ────────────────────────────────────────────────

# Your Railway backend URL after deployment
NEXT_PUBLIC_API_URL="https://mindcare-api.railway.app/api/v1"
