{
  "name": "mindcare",
  "version": "1.0.0",
  "private": true,
  "description": "MindCare — Counselling & Wellness Platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "next dev --port 3000",
    "dev:backend": "nodemon --exec tsx src/server.ts",
    "build": "next build",
    "start": "next start",
    "build:api": "prisma generate",
    "start:api": "node -r tsx/cjs src/server.ts",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "next lint"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.0",
    "@prisma/client": "^5.14.0",
    "autoprefixer": "^10.4.0",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.0",
    "class-variance-authority": "^0.7.0",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.0",
    "cookie-parser": "^1.4.0",
    "cors": "^2.8.0",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "lucide-react": "^0.370.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.4-lts.1",
    "next": "^14.2.0",
    "next-themes": "^0.3.0",
    "nodemailer": "^6.9.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.0",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@tailwindcss/forms": "^0.5.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/cookie-parser": "^1.4.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.9.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^6.4.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.14.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
